# Fielddesk V3 Phase-1 Backend - Local Testing Environment
# Copy this file to .env and fill in actual values

# REQUIRED: PostgreSQL connection string
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/fielddesk_v3

# REQUIRED: JWT signing secret for access tokens and onboarding tokens
# Use a strong random string. In production, use a secrets manager.
JWT_SECRET=your-secret-key-here-change-in-production

# REQUIRED: Root domain for tenant resolution (e.g., localhost:3000 for local, example.com for prod)
# Must match the Host header in requests
ROOT_DOMAIN=localhost:3000

# OPTIONAL: HTTP port (default: 3000)
PORT=3000

# OPTIONAL: Node environment (development | production)
# In development, stack traces are shown in error responses. In production, details are hidden.
NODE_ENV=development

# OPTIONAL: Separate JWT secret for onboarding tokens
# If omitted, JWT_SECRET is used for both access and onboarding tokens
# INVITATION_JWT_SECRET=your-onboarding-secret-here

# OPTIONAL: Required for POST /v1/invitations (global-admin invite creation)
# GLOBAL_ADMIN_API_KEY=change-me
