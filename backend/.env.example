# Fielddesk V3 Phase-1 Backend - Local Testing Environment
# Copy this file to .env and fill in actual values

# REQUIRED: PostgreSQL connection string
# Format: postgresql://user:password@host:port/database
# Default local Postgres uses 5432. Port 55432 is only for a local Docker/tunnel/proxy setup if you started one explicitly.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/fielddesk_v3

# REQUIRED: JWT signing secret for access tokens and onboarding tokens
# Use a strong random string. In production, use a secrets manager.
JWT_SECRET=your-secret-key-here-change-in-production

# REQUIRED: Root domain for tenant resolution (e.g., localhost:3000 for local, example.com for prod)
# Must match the Host header in requests
ROOT_DOMAIN=localhost:3000

# OPTIONAL: HTTP port (default: 3000)
PORT=3000

# OPTIONAL: Node environment (development | production)
# In development, stack traces are shown in error responses. In production, details are hidden.
NODE_ENV=development

# OPTIONAL in development/test. REQUIRED in production for Redis-backed rate limiting.
# If omitted in development/test, auth rate limiting falls back to in-memory per-process limits.
# REDIS_URL=
# REDIS_TOKEN=

# OPTIONAL: Separate JWT secret for onboarding tokens
# If omitted, JWT_SECRET is used for both access and onboarding tokens
# INVITATION_JWT_SECRET=your-onboarding-secret-here

# OPTIONAL: Required for POST /v1/invitations (global-admin invite creation)
# GLOBAL_ADMIN_API_KEY=change-me
# OPTIONAL: Project Equipment CCTV beta gate. Disabled unless explicitly enabled.
PROJECT_EQUIPMENT_BETA_ENABLED=false
# Optional comma-separated UUID allowlists. Leave blank for no extra beta scoping.
# PROJECT_EQUIPMENT_BETA_TENANT_IDS=
# PROJECT_EQUIPMENT_BETA_PROJECT_IDS=
# PROJECT_EQUIPMENT_BETA_USER_IDS=
# OPTIONAL until a module enables file flows. REQUIRED before production file upload/download.
# Fielddesk stores file binaries in Azure Blob Storage. The backend owns all Azure access.
FD_STORAGE_PROVIDER=azure_blob
FD_AZURE_STORAGE_CONNECTION_STRING=
FD_AZURE_STORAGE_CONTAINER=fielddesk-files
FD_STORAGE_MAX_UPLOAD_MB=10
FD_DRAWING_PDF_MAX_UPLOAD_MB=50

# OPTIONAL: Tenant user account setup mail.
# Keep disabled until a real provider, verified sending domain, and API key are configured.
MAIL_PROVIDER=disabled
# Supported provider values: disabled, resend, postmark
# MAIL_FROM=Fielddesk <noreply@mail.fielddesk.dk>
# MAIL_REPLY_TO=support@fielddesk.dk
# MAIL_API_KEY=
# MAIL_STREAM=outbound
# Optional override for account setup links. Use {tenant} if the provider needs a tenant slug template.
# TENANT_INVITE_BASE_URL=https://{tenant}.fielddesk.dk
